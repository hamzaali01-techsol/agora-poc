# Agora App ID (public — used client-side)
NEXT_PUBLIC_AGORA_APP_ID=

# Agora RESTful API credentials (server-side only — for cloud recording)
AGORA_APP_ID=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# AWS S3 config for recording uploads
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=0
# 0=US_EAST_1, 1=US_EAST_2, 2=US_WEST_1, 3=US_WEST_2,
# 4=EU_WEST_1, 5=EU_WEST_2, 6=EU_CENTRAL_1,
# 7=AP_SOUTHEAST_1, 8=AP_SOUTHEAST_2, 9=AP_NORTHEAST_1,
# 10=AP_NORTHEAST_2, 11=SA_EAST_1
S3_FILE_PREFIX=agora-recordings
